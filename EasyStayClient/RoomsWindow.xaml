<Window x:Class="EasyStayClient.RoomsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление Номерами" 
        Width="1440" Height="1024"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Button x:Name="BtnBack" 
                Content="Вернуться в главное меню"
                HorizontalAlignment="Left"
                Margin="51,42,0,0"
                VerticalAlignment="Top"
                FontSize="44"
                FontFamily="Archivo Black"
                Foreground="#767676"
                Background="Transparent"
                BorderBrush="Transparent"
                Cursor="Hand" 
                Click="BtnBack_Click"/>

        <TextBlock Text="Управление Номерами" 
                   FontSize="89" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   TextAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="51,119,0,0"
                   VerticalAlignment="Top"/>

        <TextBlock Text="Id отеля" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="110,261,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtHotelId" 
                 Width="822" Height="75"
                 HorizontalAlignment="Left"
                 Margin="110,328,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Чтобы управлять номера нужно изначально указать id отеля в котором эти номера располагаются" 
                   FontSize="33" 
                   FontFamily="Anek Latin" 
                   Foreground="#857D7D"
                   HorizontalAlignment="Left"
                   Margin="112,415,0,0"
                   VerticalAlignment="Top"
                   TextWrapping="Wrap"
                   Width="1220"/>

        <Button x:Name="BtnAddRoom" 
                Width="1220" Height="119"
                HorizontalAlignment="Left"
                Margin="110,570,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnAddRoom_Click">
            <TextBlock Text="Добавить номер" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>

        <Button x:Name="BtnEditRoom" 
                Width="1220" Height="119"
                HorizontalAlignment="Left"
                Margin="109,714,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnEditRoom_Click">
            <TextBlock Text="Изменить данные о номере" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>

        <Button x:Name="BtnDeleteRoom" 
                Width="1220" Height="119"
                HorizontalAlignment="Left"
                Margin="109,858,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnDeleteRoom_Click">
            <TextBlock Text="Удалить номер" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>
    </Grid>
</Window>