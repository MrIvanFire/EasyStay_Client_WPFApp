<Window x:Class="EasyStayClient.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Главное меню" 
        Width="1440" Height="1024"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid> 
        <TextBlock Text="Главное меню" 
                   FontSize="89" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   TextAlignment="Center"
                   Margin="0,84,0,0"
                   VerticalAlignment="Top"/>
 
        <Button x:Name="BtnHotels" 
                Width="1220" Height="134"
                HorizontalAlignment="Left"
                Margin="108,265,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnHotels_Click">
            <TextBlock Text="Управление Отелями" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"/>
        </Button>
 
        <Button x:Name="BtnBookings" 
                Width="1220" Height="134"
                HorizontalAlignment="Left"
                Margin="110,426,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnBookings_Click">
            <TextBlock Text="Управление Бронью" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"/>
        </Button>
 
        <Button x:Name="BtnRooms" 
                Width="1226" Height="134"
                HorizontalAlignment="Left"
                Margin="102,587,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnRooms_Click">
            <TextBlock Text="Управление Номерами" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"/>
        </Button>

       
        <Button x:Name="BtnReviews" 
                Width="1221" Height="186"
                HorizontalAlignment="Left"
                Margin="107,750,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnReviews_Click">
            <TextBlock Text="Управление Отзывами" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </Button>
 
       
    </Grid>
</Window>