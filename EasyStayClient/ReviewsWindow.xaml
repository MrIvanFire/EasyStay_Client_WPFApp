<Window x:Class="EasyStayClient.ReviewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление Отзывами" 
        Width="1440" Height="1024"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Button x:Name="BtnBack" 
                Content="Вернуться в главное меню"
                HorizontalAlignment="Left"
                Margin="51,42,0,0"
                VerticalAlignment="Top"
                FontSize="44"
                FontFamily="Archivo Black"
                Foreground="#767676"
                Background="Transparent"
                BorderBrush="Transparent"
                Cursor="Hand" 
                Click="BtnBack_Click"/>

        <TextBlock Text="Управление Отзывами" 
                   FontSize="89" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="63,168,0,0"
                   VerticalAlignment="Top"/>

        <TextBlock Text="Id отзыва" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="63,342,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtReviewId" 
                 Width="573" Height="74"
                 HorizontalAlignment="Left"
                 Margin="63,410,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <Button x:Name="BtnDeleteReview" 
                Width="801" Height="116"
                HorizontalAlignment="Left"
                Margin="63,545,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnDeleteReview_Click">
            <TextBlock Text="Удалить отзыв" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>
    </Grid>
</Window>