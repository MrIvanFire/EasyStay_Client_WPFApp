<Window x:Class="EasyStayClient.HotelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление Отелями" 
        Width="1440" Height="1024"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Button x:Name="BtnBack" 
                Content="Вернуться в главное меню"
                HorizontalAlignment="Left"
                Margin="51,42,0,0"
                VerticalAlignment="Top"
                FontSize="44"
                FontFamily="Archivo Black"
                Foreground="#767676"
                Background="Transparent"
                BorderBrush="Transparent"
                Cursor="Hand"
                Click="BtnBack_Click"/>

        <TextBlock Text="Управление Отелями" 
                   FontSize="89" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   TextAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="51,172,0,0"
                   VerticalAlignment="Top"/>

        <Button x:Name="BtnAddHotel" 
                Width="1220" Height="134"
                HorizontalAlignment="Left"
                Margin="110,393,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnAddHotel_Click">
            <TextBlock Text="Добавить отель" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>

        <Button x:Name="BtnEditHotel" 
                Width="1220" Height="134"
                HorizontalAlignment="Left"
                Margin="109,555,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnEditHotel_Click">
            <TextBlock Text="Изменить данные отеля" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>

        <Button x:Name="BtnDeleteHotel" 
                Width="1220" Height="134"
                HorizontalAlignment="Left"
                Margin="109,717,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnDeleteHotel_Click">
            <TextBlock Text="Удалить отель" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>
    </Grid>
</Window>