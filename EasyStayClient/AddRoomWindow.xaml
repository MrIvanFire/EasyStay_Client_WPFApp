<Window x:Class="EasyStayClient.AddRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить номер" 
        Width="1440" Height="1024"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Button x:Name="BtnBack" 
                Content="Вернуться в меню управления номерами"
                HorizontalAlignment="Right"
                Margin="0,20,35,0"
                VerticalAlignment="Top"
                FontSize="34"
                FontFamily="Archivo Black"
                Foreground="#767676"
                Background="Transparent"
                BorderBrush="Transparent"
                Cursor="Hand" 
                Click="BtnBack_Click"/>

        <TextBlock Text="Добавить номер" 
                   FontSize="89" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="53,139,0,0"
                   VerticalAlignment="Top"/>

        <TextBlock Text="Номер комнаты" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="49,286,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtRoomNumber" 
                 Width="589" Height="75"
                 HorizontalAlignment="Left"
                 Margin="49,353,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Тип номера" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="49,442,0,0"
                   VerticalAlignment="Top"/>

        <ComboBox x:Name="RoomType" 
                  Width="435" Height="74"
                  HorizontalAlignment="Left"
                  Margin="49,510,0,0"
                  VerticalAlignment="Top"
                  Background="White"
                  BorderBrush="Black"
                  BorderThickness="2"
                  FontSize="24"
                  VerticalContentAlignment="Center"/>

        <TextBlock Text="Описание" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="49,598,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtDescription" 
                 Width="435" Height="74"
                 HorizontalAlignment="Left"
                 Margin="49,666,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Ссылка на фото" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="720,286,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtPhotoUrl" 
                 Width="601" Height="75"
                 HorizontalAlignment="Left"
                 Margin="720,353,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="20"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <Button x:Name="BtnAdd" 
                Width="801" Height="116"
                HorizontalAlignment="Left"
                Margin="73,769,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnAdd_Click">
            <TextBlock Text="Добавить" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>
    </Grid>
</Window>