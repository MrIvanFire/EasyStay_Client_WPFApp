<Window x:Class="EasyStayClient.EditHotelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменить данные об отеле" 
        Width="1440" Height="1024"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Button x:Name="BtnBack" 
                Content="Вернуться в меню управления отелями"
                HorizontalAlignment="Right"
                Margin="0,20,35,0"
                VerticalAlignment="Top"
                FontSize="34"
                FontFamily="Archivo Black"
                Foreground="#767676"
                Background="Transparent"
                BorderBrush="Transparent"
                Cursor="Hand" 
                Click="BtnBack_Click"/>

        <TextBlock Text="Изменить данные об отеле" 
                   FontSize="89" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="73,108,0,0"
                   VerticalAlignment="Top"/>

        <!-- Левая колонка -->
        <TextBlock Text="Id" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="73,258,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtId" 
                 Width="168" Height="74"
                 HorizontalAlignment="Left"
                 Margin="73,326,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Название" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="305,258,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtName" 
                 Width="468" Height="75"
                 HorizontalAlignment="Left"
                 Margin="305,325,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Город" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="73,414,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtCity" 
                 Width="435" Height="74"
                 HorizontalAlignment="Left"
                 Margin="73,482,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Адрес" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="77,564,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtAddress" 
                 Width="801" Height="75"
                 HorizontalAlignment="Left"
                 Margin="77,631,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Рейтинг" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="77,716,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtRating" 
                 Width="283" Height="74"
                 HorizontalAlignment="Left"
                 Margin="77,784,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Описание" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="386,716,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtDescription" 
                 Width="492" Height="74"
                 HorizontalAlignment="Left"
                 Margin="386,784,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <!-- Правая колонка - фото -->
        <TextBlock Text="Ссылки на фото" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="817,215,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtPhotoUrls" 
                 Width="576" Height="231"
                 HorizontalAlignment="Left"
                 Margin="817,287,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="20"
                 VerticalContentAlignment="Top"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Padding="10,10,0,0"
                 ToolTip="Введите ссылки на фото, каждую с новой строки или через запятую"/>

        <TextBlock Text="Несколько ссылок через запятую или с новой строки" 
                   FontSize="24" 
                   FontFamily="Anek Latin" 
                   Foreground="#858585"
                   HorizontalAlignment="Left"
                   Margin="817,534,0,0"
                   VerticalAlignment="Top"/>

        <Button x:Name="BtnConfirm" 
                Width="801" Height="116"
                HorizontalAlignment="Left"
                Margin="73,872,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnConfirm_Click">
            <TextBlock Text="Подтвердить" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>
    </Grid>
</Window>