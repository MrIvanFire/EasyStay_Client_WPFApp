<Window x:Class="EasyStayClient.AddHotelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить отель" 
        Width="1440" Height="1024"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Button x:Name="BtnBack" 
                Content="Вернуться в меню управления отелями"
                HorizontalAlignment="Right"
                Margin="0,20,35,0"
                VerticalAlignment="Top"
                FontSize="34"
                FontFamily="Archivo Black"
                Foreground="#767676"
                Background="Transparent"
                BorderBrush="Transparent"
                Cursor="Hand" 
                Click="BtnBack_Click"/>

        <TextBlock Text="Добавить отель" 
                   FontSize="89" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="77,73,0,0"
                   VerticalAlignment="Top"/>

        <TextBlock Text="Название" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="73,220,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtName" 
                 Width="589" Height="75"
                 HorizontalAlignment="Left"
                 Margin="73,287,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Город" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="73,376,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtCity" 
                 Width="435" Height="74"
                 HorizontalAlignment="Left"
                 Margin="73,444,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Адрес" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="77,526,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtAddress" 
                 Width="801" Height="75"
                 HorizontalAlignment="Left"
                 Margin="77,593,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Рейтинг" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="77,678,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtRating" 
                 Width="283" Height="74"
                 HorizontalAlignment="Left"
                 Margin="77,746,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Описание" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="386,678,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtDescription" 
                 Width="492" Height="74"
                 HorizontalAlignment="Left"
                 Margin="386,746,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <TextBlock Text="Ссылки на фото" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="720,220,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtPhotoUrls" 
         Width="673" Height="231"
         HorizontalAlignment="Left"
         Margin="720,287,0,0"
         VerticalAlignment="Top"
         Background="White"
         BorderBrush="Black"
         BorderThickness="2"
         FontSize="20"
         VerticalContentAlignment="Top"
         TextWrapping="Wrap"
         AcceptsReturn="True"
         Padding="10,10,0,0"
         ToolTip="Введите ссылки на фото, каждую с новой строки или через запятую"/>
        <TextBlock Text="Несколько ссылок через запятую или с новой строки" 
                   FontSize="24" 
                   FontFamily="Anek Latin" 
                   Foreground="#858585"
                   HorizontalAlignment="Left"
                   Margin="720,531,0,0"
                   VerticalAlignment="Top"/>

        <Button x:Name="BtnAdd" 
                Width="801" Height="116"
                HorizontalAlignment="Left"
                Margin="73,834,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnAdd_Click">
            <TextBlock Text="Добавить" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>
    </Grid>
</Window>