<Window x:Class="EasyStayClient.DeleteRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Удалить номер" 
        Width="1440" Height="1024"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Button x:Name="BtnBack" 
                Content="Вернуться в меню управления номерами"
                HorizontalAlignment="Right"
                Margin="0,20,35,0"
                VerticalAlignment="Top"
                FontSize="34"
                FontFamily="Archivo Black"
                Foreground="#767676"
                Background="Transparent"
                BorderBrush="Transparent"
                Cursor="Hand" 
                Click="BtnBack_Click"/>

        <TextBlock Text="Удалить номер" 
                   FontSize="89" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="73,189,0,0"
                   VerticalAlignment="Top"/>

        <TextBlock Text="Номер комнаты" 
                   FontSize="57" 
                   FontFamily="Anek Latin" 
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="73,404,0,0"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="TxtRoomNumber" 
                 Width="573" Height="74"
                 HorizontalAlignment="Left"
                 Margin="73,472,0,0"
                 VerticalAlignment="Top"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 FontSize="24"
                 VerticalContentAlignment="Center"
                 Padding="10,0,0,0"/>

        <Button x:Name="BtnDelete" 
                Width="801" Height="116"
                HorizontalAlignment="Left"
                Margin="73,599,0,0"
                VerticalAlignment="Top"
                Background="#D9D9D9"
                BorderBrush="#D9D9D9"
                Cursor="Hand"
                Click="BtnDelete_Click">
            <TextBlock Text="Удалить" 
                       FontSize="54" 
                       FontFamily="Archivo Black" 
                       Foreground="Black"
                       TextAlignment="Center"/>
        </Button>
    </Grid>
</Window>